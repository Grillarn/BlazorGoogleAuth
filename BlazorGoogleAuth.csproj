<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>blazor-google-auth-secrets</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Google" Version="8.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="8.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.10">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <!-- EkoWebApi är ett eget, separat projekt som råkar ligga i en undermapp
       här - exkludera det så SDK:ns default-glob inte plockar upp dess filer. -->
  <ItemGroup>
    <Compile Remove="EkoWebApi\**" />
    <Content Remove="EkoWebApi\**" />
    <EmbeddedResource Remove="EkoWebApi\**" />
    <None Remove="EkoWebApi\**" />
  </ItemGroup>

</Project>
