@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me">Inloggad som <strong>@context.User.Identity?.Name</strong></span>
                    <form method="post" action="/logout">
                        <button type="submit" class="btn-link">Logga ut</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="login">Logga in med Google</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
