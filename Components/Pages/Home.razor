@page "/"

<PageTitle>Hem</PageTitle>

<h1>Blazor + Google OAuth</h1>

<AuthorizeView>
    <Authorized>
        <p>Välkommen, <strong>@context.User.Identity?.Name</strong>! Du är inloggad via Google.</p>
        <p><a href="profile">Visa din profil och dina roller</a></p>
        @if (context.User.IsInRole("Admin"))
        {
            <p>🔑 Du har rollen <strong>Admin</strong> – se <a href="admin">adminpanelen</a>.</p>
        }
    </Authorized>
    <NotAuthorized>
        <p>Du är inte inloggad.</p>
        <a class="btn btn-primary" href="login">Logga in med Google</a>
    </NotAuthorized>
</AuthorizeView>
