@page "/profile"
@attribute [Authorize]

<PageTitle>Min profil</PageTitle>

<h1>Min profil</h1>

<AuthorizeView>
    <Authorized>
        <h2>Roller</h2>
        @{
            var roles = context.User.Claims
                .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
                .Select(c => c.Value)
                .ToList();
        }
        <div class="card">
            @if (roles.Count > 0)
            {
                @foreach (var role in roles)
                {
                    <span class="role-badge">@role</span>
                }
            }
            else
            {
                <span class="empty-state">Inga roller tilldelade</span>
            }
        </div>

        <h2>Alla claims</h2>
        <div class="card card-table">
            <table class="table">
                <thead>
                    <tr>
                        <th>Typ</th>
                        <th>Värde</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var claim in context.User.Claims)
                    {
                        <tr>
                            <td>@claim.Type.Split('/').Last()</td>
                            <td>@claim.Value</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </Authorized>
</AuthorizeView>
